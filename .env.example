# ========================================================================
# Docker Compose 环境变量(根目录)—— 复制为 .env 后填值。
# 既用于 compose 变量插值(mysql/redis),也作为 api 容器的 env_file。
# .env 已在 .gitignore 中,严禁提交真实密钥。
# ========================================================================

# ---- 应用 ----
APP_ENV=prod
DEBUG=false
API_PREFIX=/api/v1

# ---- MySQL(容器内 host = 服务名 mysql)----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=wx_mp
MYSQL_USER=mpuser
MYSQL_PASSWORD=change_me_mp_pass
MYSQL_ROOT_PASSWORD=change_me_root_pass

# ---- Redis(容器内 host = 服务名 redis)----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----
# python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-generate-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- AppSecret 加密主密钥(32 字节 base64)----
# python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MP_SECRET_MASTER_KEY=
MP_SECRET_KEY_VERSION=1

# ---- wx-gateway 内部凭据接口令牌 ----
INTERNAL_TOKEN=please-generate-another-random-string

# ---- 首启超级管理员 ----
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=Admin@12345

# ---- 全局发布审核开关(M2+)----
PUBLISH_REVIEW_ENABLED=true

# ---- 火山方舟 Coding Plan(AI 能力接入)----
# API Key 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
VOLC_ARK_API_KEY=
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
VOLC_ARK_MODEL=ark-code-latest
VOLC_ARK_TIMEOUT_SECONDS=60
