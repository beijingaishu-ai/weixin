# ========================================================================
# 微信公众号矩阵管理系统 —— 环境变量样例
# 复制为 backend/.env(本地) 或 deploy/app.env(容器),再填入真实值。
# .env / *.env 已列入 .gitignore,严禁提交真实密钥。
# ========================================================================

# ---- 应用 ----
APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mpuser
MYSQL_PASSWORD=mp_pass_change_me
MYSQL_DB=wx_mp

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT(HS256 双令牌)----
# 生成:python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-generate-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- AppSecret 加密主密钥(AES-256-GCM,32 字节 base64)----
# 生成:python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MP_SECRET_MASTER_KEY=
MP_SECRET_KEY_VERSION=1

# ---- wx-gateway 内部凭据接口共享令牌(X-Internal-Token)----
INTERNAL_TOKEN=please-generate-another-random-string

# ---- 首次启动自动创建的超级管理员(仅当账号不存在时)----
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=Admin@12345

# ---- 全局发布审核开关(M2+ 生效,与号级 need_review 双层叠加)----
PUBLISH_REVIEW_ENABLED=true

# ---- 火山方舟 Coding Plan(AI 能力接入)----
# API Key 获取地址: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey
VOLC_ARK_API_KEY=
# Base URL 固定为 Coding Plan 专用地址,请勿使用在线推理接口地址
VOLC_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# 可选模型:ark-code-latest(控制台切换)、doubao-seed-2.0-code、glm-4.7、deepseek-v3.2、kimi-k2.5 等
VOLC_ARK_MODEL=ark-code-latest
VOLC_ARK_TIMEOUT_SECONDS=60
